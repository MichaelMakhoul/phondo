{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "regions": ["syd1"],
  "crons": [
    {
      "path": "/api/cron/expire-callbacks",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/callback-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 12 * * *"
    }
  ]
}
