# Supabase (hosted in ap-southeast-2 / Sydney for AU data sovereignty)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe (create products in AUD in Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# ElevenLabs (for voice preview)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Email Notifications (Resend)
EMAIL_API_KEY=re_...
EMAIL_FROM=notifications@yourdomain.com

# SMS Notifications (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1...
# Validated Twilio Address SID, attached at purchase for countries that require a
# regulatory/emergency address (e.g. AU — Twilio error 21631 without it).
TWILIO_ADDRESS_SID=AD...

# Telnyx (AU telephony provider — cheaper alternative to Twilio for AU numbers)
TELNYX_API_KEY=KEY...
TELNYX_TEXML_APP_ID=your-texml-application-id
TELNYX_MESSAGING_PROFILE_ID=your-messaging-profile-id
# TELNYX_PUBLIC_KEY=your-public-key-for-webhook-signature-verification

# Calendar Integration (Cal.com)
CAL_COM_API_KEY=cal_...

# Security
ENCRYPTION_KEY=base64-encoded-32-byte-key

# Internal API (shared secret with self-hosted voice server)
INTERNAL_API_SECRET=random-secret-here

# Self-hosted voice server
VOICE_SERVER_PUBLIC_URL=https://your-voice-server.example.com
TEST_CALL_SECRET=random-secret-shared-with-voice-server

# Anthropic (used for LLM extraction during website scraping)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (used by the voice server — see voice-server/.env.example)
# OPENAI_API_KEY=sk-...

# Upstash Redis (demo call rate limiting — optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Vercel Cron (auto-injected on Vercel, set manually for local testing)
CRON_SECRET=your-cron-secret

# Admin Alerts (health check monitoring — optional)
ADMIN_ALERT_EMAIL=admin@yourdomain.com
ADMIN_ALERT_PHONE=+1234567890

# Sentry (error tracking — optional, disabled when not set)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_DSN is for the voice server (see voice-server/.env.example)

# Grafana Cloud Loki — direct push of pageSentry's [ALERT] lines (SCRUM-323).
# Dormant unless ALL THREE are set. Lets Next.js errors reach Grafana for
# alerting without a Vercel log drain (drains need Pro; we're on Hobby).
# Get these from Grafana Cloud → Connections → Loki → Details:
#   LOKI_PUSH_URL  = the push endpoint, e.g. https://logs-prod-XX.grafana.net/loki/api/v1/push
#   LOKI_USERNAME  = the Loki instance / user ID (numeric)
#   LOKI_API_TOKEN = a Grafana Cloud access-policy token with logs:write scope
LOKI_PUSH_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
LOKI_USERNAME=123456
LOKI_API_TOKEN=glc_...

# UptimeRobot (external monitoring — optional, for future programmatic management)
# UPTIMEROBOT_API_KEY=ur_...

# Google Analytics 4 (optional — dormant when unset)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog product analytics (SCRUM-566, optional — dormant when unset).
# Project API key from the Phondo organization on PostHog EU cloud.
# Requests go through the first-party /ingest proxy (next.config.ts) — leave
# NEXT_PUBLIC_POSTHOG_HOST unset unless deliberately bypassing the proxy.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=/ingest

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pre-launch kill switches (default closed). Flip to "true" ONLY when ready to open up.
# NEXT_PUBLIC_ENABLE_SIGNUP gates the public signup page UI.
# PROVISIONING_ENABLED gates the server-side /api/v1/phone-numbers POST (real carrier purchases).
# NEXT_PUBLIC_PROVISIONING_ENABLED is the client mirror of PROVISIONING_ENABLED: when off,
# the onboarding "Go Live" step hides paid plans + number search and completes everyone on
# the 14-day trial (no payment). Set BOTH to "true" together at launch to restore the full flow.
NEXT_PUBLIC_ENABLE_SIGNUP=false
PROVISIONING_ENABLED=false
NEXT_PUBLIC_PROVISIONING_ENABLED=false

# DUNNING_SMS_ENABLED gates the subscription-dunning SMS variant (SCRUM-478).
# Default off — the dunning cron emails owners about subscription lapse; the SMS
# copy is written but only sends when this is "true" AND the org has the
# smsNotifications plan flag AND its sms_on_subscription_dunning pref is on.
DUNNING_SMS_ENABLED=false

# Cloudflare Turnstile CAPTCHA for Supabase Auth (SCRUM-436).
# Site key is PUBLIC (inlined into the client bundle). Leave unset to disable
# the widget — auth calls then omit captchaToken. The Supabase dashboard
# CAPTCHA toggle must only be enabled AFTER this is set and deployed.
# NOTE: the toggle is project-wide — once ON, EVERY client of this Supabase
# project (local dev, Vercel previews) needs this key set AND its hostname
# (localhost, *.vercel.app) allowlisted in the Turnstile widget's domain
# config, or auth in that environment fails with "Security check failed".
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Cliniko CRM integration (SCRUM-12)
# Contact email sent in the Cliniko API User-Agent header (Cliniko requires a
# name + valid contact email on every request; requests without one may be blocked).
CLINIKO_CONTACT_EMAIL=michaelmakhoul0@gmail.com
