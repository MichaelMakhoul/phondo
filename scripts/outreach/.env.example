# Phondo OUTREACH email config — SEPARATE from the app's transactional email.
#
# 1. Create a NEW key in the PHONDO Resend account (not Queroa):
#    Resend dashboard → confirm the account/team name reads "phondo" (top-left switcher)
#    → API Keys → Create → name "phondo-outreach", permission "Sending access".
#    Do NOT reuse EMAIL_API_KEY — that is the app's transactional key, and cold
#    outreach complaints would poison deliverability for your customers' call
#    alerts and billing emails.
#
# 2. Copy this file to  scripts/outreach/.env  (already gitignored) and fill it in.
#    Never put the outreach key in .env.local — the Next app would pick it up.

RESEND_OUTREACH_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Send from a phondo.ai address that is VERIFIED in the same Resend account.
# RECOMMENDED: a subdomain (e.g. michael@go.phondo.ai) so cold-outreach reputation
# is walled off from your transactional/root-domain reputation. A subdomain is free
# (just DNS records). If you use the bare root @phondo.ai it works, but shares
# reputation with your transactional email — acceptable at low volume, not ideal.
OUTREACH_FROM=Michael from Phondo <michael@phondo.ai>

# Replies land in your real inbox.
OUTREACH_REPLY_TO=michaelmakhoul0@gmail.com

# Phone number shown in the signature. Use a Twilio number (that forwards to you or is
# answered by a Phondo assistant), NOT your personal mobile. Defaults to a placeholder.
OUTREACH_PHONE=0400 000 000
