{
  "compilerOptions": {
    "checkJs": true,
    "noEmit": true,
    "allowJs": true,
    "target": "es2022",
    "lib": ["es2023"],
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "maxNodeModuleJsDepth": 0
  },
  "include": ["**/*.js"],
  "exclude": ["node_modules", "tests", "public", "scripts"]
}
