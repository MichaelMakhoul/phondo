# Twilio (Auth Token used for HMAC webhook signature verification)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telnyx (AU telephony — TeXML compatible, optional if only using Twilio)
# TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELNYX_PUBLIC_KEY=your-public-key-for-webhook-signature-verification

# Deepgram — free $200 credit at console.deepgram.com
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI — platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL (ngrok HTTPS URL or Fly.io URL, no trailing slash)
PUBLIC_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app

# Public URL of the Next.js app — used to build recording webhook URLs that
# Twilio/Telnyx will POST to. REQUIRED for call recording to work; if unset,
# recording is silently disabled.
APP_PUBLIC_URL=

# Server port
PORT=3001

# Supabase (service role for database access)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Internal API (Next.js app for post-call processing)
INTERNAL_API_URL=https://your-app.vercel.app
INTERNAL_API_SECRET=random-secret-here

# Test calls (browser WebSocket — shared secret with Next.js app)
TEST_CALL_SECRET=random-secret-shared-with-nextjs-app

# Sentry (error tracking — optional, disabled when not set)
SENTRY_DSN=https://your-dsn@sentry.io/project-id
